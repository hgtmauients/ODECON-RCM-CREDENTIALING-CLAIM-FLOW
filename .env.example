# NoodleDoc Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.

# ─── Application ────────────────────────────────────────
# One of: development, test, staging, production
ENV=development
PORT=8000
# Comma-separated list of allowed browser origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
# Optional release identifier shown in Sentry / logs
# RELEASE_VERSION=v1.2.3

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://noodledoc:noodledoc@localhost:5432/noodledoc
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
SQL_ECHO=false
# Required by docker-compose.prod.yml when using the prod stack
# POSTGRES_PASSWORD=

# ─── Cache / Coordination (multi-worker) ───────────────
# When set, used for: rate limiter buckets, webhook nonce dedup
REDIS_URL=

# ─── Authentication ─────────────────────────────────────
# Development (HS256, 32+ chars):
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-base64-32
JWT_ALGORITHM=HS256
JWT_AUDIENCE=claimflow
JWT_ISSUER=

# For production (RS256 with OIDC provider):
# JWT_ALGORITHM=RS256
# JWT_JWKS_URL=https://your-idp.com/.well-known/jwks.json
# JWT_ISSUER=https://your-idp.com/

# ─── Encryption ─────────────────────────────────────────
# Active key for encrypt + decrypt. Base64-encoded 32-byte key:
#   openssl rand -base64 32
CLAIMFLOW_ENCRYPTION_KEY=
# Version slot (1..255) the active key occupies. Bump on every rotation
# AND park the previous active key in CLAIMFLOW_ENCRYPTION_KEY_v<previous>.
CLAIMFLOW_ENCRYPTION_KEY_VERSION=1
# Optional historical keys for graceful rotation (decrypt-only).
# CLAIMFLOW_ENCRYPTION_KEY_v0=
# CLAIMFLOW_ENCRYPTION_KEY_v1=

# ─── Webhook Security ───────────────────────────────────
# NB: the per-tenant webhook_secret in tenant Settings is REQUIRED for the
# provider-signup webhook. There is no shared env-var fallback (would break
# multi-tenant isolation). The variable below is reserved for non-tenant
# webhooks and the in-process WEBHOOK_REPLAY_WINDOW.
WEBHOOK_SECRET=
WEBHOOK_REPLAY_WINDOW=300

# ─── Rate Limiting ──────────────────────────────────────
# Bucket key is per CLIENT IP only. We deliberately do not bucket on
# X-Tenant-ID — that header is not authenticated until the auth layer runs.
# Default 600/min is intentionally generous because multiple tenants behind
# the same office NAT share one bucket; tighten if you need stricter limits.
RATE_LIMIT_REQUESTS=600
RATE_LIMIT_WINDOW=60

# ─── EDI Upload / Storage ───────────────────────────────
# Defaults to 10 MB
MAX_EDI_UPLOAD_BYTES=10485760
# Defaults to 20 MB
MAX_DOC_UPLOAD_BYTES=20971520
# Defaults to 20 MB — applied to fee-schedule + claims CSV imports
MAX_FEE_SCHEDULE_BYTES=20971520
MAX_CLAIMS_CSV_BYTES=20971520

# Storage backend for uploaded files: "local" or "s3"
STORAGE_BACKEND=local
EDI_STORAGE_PATH=/data/edi
# Required when STORAGE_BACKEND=s3
S3_BUCKET=
S3_REGION=us-east-1

# ─── Logging ────────────────────────────────────────────
# Threshold (ms) above which DB queries are logged at WARN.
SLOW_QUERY_MS=500
# Force JSON logging in non-prod environments. Production defaults to JSON.
# LOG_FORMAT=json

# ─── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@noodledoc.com

# ─── Feature Flags ──────────────────────────────────────
CLAIMFLOW_ENABLE_EMR_CONNECTOR=false
CLAIMFLOW_ENABLE_CLINICAL_NOTES=false
# When true, this worker can run scheduled jobs (advisory-locked, so safe to
# enable on all workers). When false, no jobs run from this process.
CLAIMFLOW_SCHEDULER_ENABLED=false

# ─── CAQH ProView ───────────────────────────────────────
# Apply at https://proview.caqh.org as a Participating Organization
CAQH_ORG_ID=
CAQH_USERNAME=
CAQH_PASSWORD=
CAQH_BASE_URL=https://proview-demo.caqh.org/RosterAPI/api

# ─── API-Cert (License Verification) ────────────────────
# Free: 50 verifications/month. Register at api-cert.com
API_CERT_KEY=
API_CERT_BASE_URL=https://api.api-cert.com

# ─── Provider Verification Adapter ───────────────────────
# ClaimFlow calls these URLs for license/background checks. In local docker
# compose defaults point to the built-in adapter service (provider-adapter:8010).
# In production, set these to your adapter domain.
STATE_LICENSE_PROVIDER_URL=
BACKGROUND_CHECK_PROVIDER_URL=

# Adapter service upstream vendor passthrough (set on adapter container).
# Leave empty to use deterministic starter/mock behavior.
LICENSE_UPSTREAM_URL=
BACKGROUND_UPSTREAM_URL=
ADAPTER_HTTP_TIMEOUT_SECONDS=10

# ─── Observability (optional) ───────────────────────────
# Sentry DSN. When unset, no errors are reported.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# ─── Backup Sidecar (docker-compose.prod.yml) ──────────
# Hour (UTC, 0-23) at which the daily pg_dump runs
BACKUP_HOUR_UTC=3
RETENTION_DAYS=30
