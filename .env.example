# ClaimFlow Environment Configuration
# Copy to .env and fill in values

# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://claimflow:claimflow@localhost:5432/claimflow
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
SQL_ECHO=false

# ─── Authentication ─────────────────────────────────────
# For development (HS256):
JWT_SECRET=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-base64-32
JWT_ALGORITHM=HS256
JWT_AUDIENCE=claimflow
JWT_ISSUER=

# For production (RS256 with OIDC provider):
# JWT_ALGORITHM=RS256
# JWT_JWKS_URL=https://your-idp.com/.well-known/jwks.json
# JWT_ISSUER=https://your-idp.com/
# JWT_AUDIENCE=claimflow

# ─── Encryption ─────────────────────────────────────────
# Base64-encoded 32-byte key: openssl rand -base64 32
CLAIMFLOW_ENCRYPTION_KEY=

# ─── Webhook Security ───────────────────────────────────
WEBHOOK_SECRET=

# ─── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@claimflow.io

# ─── EDI Storage ────────────────────────────────────────
EDI_STORAGE_PATH=/data/claimflow/edi

# ─── Application ────────────────────────────────────────
ENV=development
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO

# ─── Feature Flags (all disabled by default) ────────────
CLAIMFLOW_ENABLE_EMR_CONNECTOR=false
CLAIMFLOW_ENABLE_CLINICAL_NOTES=false
CLAIMFLOW_SCHEDULER_ENABLED=false

# ─── CAQH ProView ───────────────────────────────────────
# Apply at https://proview.caqh.org as a Participating Organization
CAQH_ORG_ID=
CAQH_USERNAME=
CAQH_PASSWORD=
CAQH_BASE_URL=https://proview-demo.caqh.org/RosterAPI/api

# ─── API-Cert (License Verification) ────────────────────
# Free: 50 verifications/month. Register at api-cert.com
API_CERT_KEY=
API_CERT_BASE_URL=https://api.api-cert.com
